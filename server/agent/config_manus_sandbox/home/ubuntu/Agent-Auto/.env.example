# ─── Cloudflare Workers AI Configuration ──────────────────────────────────────
# Required: API key for Cloudflare AI Gateway
CF_API_KEY=your-cloudflare-api-key-here

# Required: Cloudflare account ID
CF_ACCOUNT_ID=your-account-id-here

# Required: Cloudflare AI Gateway name
CF_GATEWAY_NAME=your-gateway-name-here

# Chat model (fast, used for regular chat mode)
CF_MODEL=@cf/meta/llama-3-8b-instruct

# Agent model (powerful, used for autonomous agent mode with tool calling)
CF_AGENT_MODEL=@cf/meta/llama-3.1-70b-instruct

# ─── Database Configuration ────────────────────────────────────────────────────
# MongoDB Atlas URI (for session persistence)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dzeck_ai?retryWrites=true&w=majority

# Redis (for session caching)
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=16364
REDIS_PASSWORD=your-redis-password-here

# Session TTL in hours (default: 24)
SESSION_TTL_HOURS=24

# ─── Browser Automation ────────────────────────────────────────────────────────
# Enable Playwright real browser (requires: playwright install chromium)
PLAYWRIGHT_ENABLED=true

# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── App Domain ───────────────────────────────────────────────────────────────
# Set this to your deployment domain (e.g., dzeck-ai.replit.app)
APP_DOMAIN=

# Expo Public Domain (used by the mobile app to connect to the API)
EXPO_PUBLIC_DOMAIN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Additional allowed origins (comma-separated)
# Example: https://myapp.com,https://admin.myapp.com
CORS_ORIGINS=

# ─── MCP Server (optional) ────────────────────────────────────────────────────
# MCP_SERVER_URL=http://localhost:3001
